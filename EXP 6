#include <stdio.h>

int main() {
    int n, bt[10], pr[10], rt[10];
    int i, time = 0, completed = 0, min, idx;
    int wt[10], tat[10];
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Enter BT and Priority for P%d: ", i+1);
        scanf("%d %d", &bt[i], &pr[i]);
        rt[i] = bt[i];
    }

    while(completed != n) {
        min = 9999;
        idx = -1;

        for(i = 0; i < n; i++) {
            if(rt[i] > 0 && pr[i] < min) {
                min = pr[i];
                idx = i;
            }
        }

        if(idx != -1) {
            rt[idx]--;
            time++;

            if(rt[idx] == 0) {
                completed++;
                wt[idx] = time - bt[idx];
                tat[idx] = wt[idx] + bt[idx];
                avg_wt += wt[idx];
                avg_tat += tat[idx];
            }
        }
    }

    printf("\nP\tBT\tPR\tWT\tTAT\n");
    for(i = 0; i < n; i++)
        printf("P%d\t%d\t%d\t%d\t%d\n", i+1, bt[i], pr[i], wt[i], tat[i]);

    printf("\nAvg WT = %.2f", avg_wt/n);
    printf("\nAvg TAT = %.2f", avg_tat/n);

    return 0;
}
