#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>

sem_t wrt;
int data=0,readcount=0;

void *reader() {
    readcount++;

    if(readcount==1)
        sem_wait(&wrt);

    printf("Reader reads %d\n",data);

    readcount--;

    if(readcount==0)
        sem_post(&wrt);

    return NULL;
}

void *writer() {
    sem_wait(&wrt);

    data++;
    printf("Writer writes %d\n",data);

    sem_post(&wrt);

    return NULL;
}

int main() {
    pthread_t r,w;

    sem_init(&wrt,0,1);

    pthread_create(&w,NULL,writer,NULL);
    pthread_create(&r,NULL,reader,NULL);

    pthread_join(w,NULL);
    pthread_join(r,NULL);

    return 0;
}
