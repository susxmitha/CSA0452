#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() 
{
    int f1, f2, n;
    char buf[100];

    f1 = open("file1.txt", O_RDONLY);
    f2 = open("file2.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);

    if(f1 < 0 || f2 < 0) 
    {
        printf("Error opening file\n");
        return 1;
    }

    while((n = read(f1, buf, 100)) > 0)
        write(f2, buf, n);

    printf("File copied\n");

    close(f1);
    close(f2);

    return 0;
}
