#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

sem_t forks[5];  // renamed from 'fork' → 'forks'

void* philosopher(void* num) 
{
    int i = *(int*)num;

    if (i % 2 == 0) 
    {
        sem_wait(&forks[i]);
        sem_wait(&forks[(i + 1) % 5]);
    } 
    else 
    {
        sem_wait(&forks[(i + 1) % 5]);
        sem_wait(&forks[i]);
    }

    printf("Philosopher %d is eating\n", i);
    sleep(1);

    sem_post(&forks[i]);
    sem_post(&forks[(i + 1) % 5]);

    return NULL;
}

int main() 
{
    pthread_t p[5];
    int i, a[5];

    for (i = 0; i < 5; i++)
        sem_init(&forks[i], 0, 1);

    for (i = 0; i < 5; i++) 
    {
        a[i] = i;
        pthread_create(&p[i], NULL, philosopher, &a[i]);
    }

    for (i = 0; i < 5; i++)
        pthread_join(p[i], NULL);

    for (i = 0; i < 5; i++)
        sem_destroy(&forks[i]);

    return 0;
}
