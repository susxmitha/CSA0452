#include <stdio.h>

int main() {
    int b[10], p[10], nb, np;
    int i, j, flag;

    printf("Enter number of blocks and processes: ");
    scanf("%d %d", &nb, &np);

    printf("Enter block sizes:\n");
    for(i = 0; i < nb; i++)
        scanf("%d", &b[i]);

    printf("Enter process sizes:\n");
    for(i = 0; i < np; i++)
        scanf("%d", &p[i]);

    for(i = 0; i < np; i++) {
        flag = 0;

        for(j = 0; j < nb; j++) {
            if(b[j] >= p[i]) {
                printf("P%d -> B%d\n", i+1, j+1);
                b[j] -= p[i];
                flag = 1;
                break;
            }
        }

        if(flag == 0) {
            printf("P%d -> Not Allocated\n", i+1);
        }
    }

    return 0;
}
