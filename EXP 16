#include <stdio.h>

struct emp {
    int id;
    char name[20];
};

int main() {
    struct emp e;
    FILE *fp;

    fp = fopen("emp.txt", "w+");

    if (fp == NULL) {
        printf("Error opening file.\n");
        return 1;
    }

    printf("Enter ID and Name: ");
    scanf("%d %19s", &e.id, e.name);

    fwrite(&e, sizeof(e), 1, fp);

    fseek(fp, 0, SEEK_SET);

    fread(&e, sizeof(e), 1, fp);

    printf("ID: %d\nName: %s\n", e.id, e.name);

    fclose(fp);
    return 0;
}
