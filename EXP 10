#include <stdio.h>
#include <sys/ipc.h>
#include <sys/msg.h>
#include <string.h>
#include <unistd.h>
#include <sys/wait.h>

struct msg 
{
    long type;
    char text[100];
};

int main() 
{
    struct msg m;
    int id = msgget(IPC_PRIVATE, 0666 | IPC_CREAT);

    if (id < 0) 
    {
        perror("msgget failed");
        return 1;
    }

    if (fork() == 0) 
    {
        msgrcv(id, &m, sizeof(m.text), 1, 0);
        printf("Child received: %s\n", m.text);
    } 
    else 
    {
        m.type = 1;
        strcpy(m.text, "Hello Child");
        msgsnd(id, &m, sizeof(m.text), 0);

        wait(NULL);  // ensure child finishes before deleting queue
        msgctl(id, IPC_RMID, NULL);
    }

    return 0;
}
