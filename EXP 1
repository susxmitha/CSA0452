#include <stdio.h>
#include <unistd.h>

int main() 
{
    int pid;

    pid = fork();

    if(pid == 0) 
    {
        printf("Child Process\n");
        printf("PID: %d\n", getpid());
        printf("Parent PID: %d\n", getppid());
    } 
    else 
    {
        printf("Parent Process\n");
        printf("PID: %d\n", getpid());
        printf("Child PID: %d\n\n", pid);
    }

    return 0;
}
