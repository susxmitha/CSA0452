#include <stdio.h>

int main() 
{
    int n, bt[10], rt[10], wt[10], tat[10];
    int i, time = 0, remain, tq;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    remain = n;

    for(i = 0; i < n; i++) 
    {
        printf("Enter BT for P%d: ", i+1);
        scanf("%d", &bt[i]);
        rt[i] = bt[i];
    }

    printf("Enter time quantum: ");
    scanf("%d", &tq);

    while(remain != 0) {
        for(i = 0; i < n; i++) 
        {
            if(rt[i] > 0) 
            {
                if(rt[i] <= tq) 
                {
                    time += rt[i];
                    wt[i] = time - bt[i];
                    tat[i] = time;
                    rt[i] = 0;
                    remain--;
                } 
                else 
                {
                    rt[i] -= tq;
                    time += tq;
                }
            }
        }
    }

    float avg_wt = 0, avg_tat = 0;

    printf("\nP\tBT\tWT\tTAT\n");
    for(i = 0; i < n; i++) 
    {
        printf("P%d\t%d\t%d\t%d\n", i+1, bt[i], wt[i], tat[i]);
        avg_wt += wt[i];
        avg_tat += tat[i];
    }

    printf("\nAvg WT = %.2f", avg_wt/n);
    printf("\nAvg TAT = %.2f", avg_tat/n);

    return 0;
}
